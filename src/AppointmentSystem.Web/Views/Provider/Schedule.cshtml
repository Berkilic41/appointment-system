@model ProviderScheduleViewModel
@{
    ViewData["Title"] = "Working Hours";
    var dayLabels = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<h1 class="h3 mb-3">Working hours & profile</h1>

<div class="row">
    <div class="col-md-7">
        <div class="card-section mb-4">
            <h2 class="h5 mb-3">Weekly schedule</h2>
            <p class="text-muted small">Times in minutes from midnight (e.g. 540 = 09:00, 1020 = 17:00). Add multiple rows per day for breaks.</p>
            <form asp-action="SaveWorkingHours" method="post">
                @Html.AntiForgeryToken()
                <table class="table align-middle">
                    <thead><tr><th>Day</th><th>Start (min)</th><th>End (min)</th><th></th></tr></thead>
                    <tbody id="hours-body">
                        @foreach (var h in Model.WorkingHours)
                        {
                            <tr>
                                <td>
                                    <select name="dayOfWeek" class="form-select form-select-sm">
                                        @for (int d = 0; d < 7; d++) { <option value="@d" selected="@(h.DayOfWeek == d)">@dayLabels[d]</option> }
                                    </select>
                                </td>
                                <td><input name="startMinutes" type="number" min="0" max="1440" value="@h.StartMinutes" class="form-control form-control-sm" /></td>
                                <td><input name="endMinutes" type="number" min="0" max="1440" value="@h.EndMinutes" class="form-control form-control-sm" /></td>
                                <td><button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button type="button" id="add-hours-row" class="btn btn-sm btn-outline-primary mb-3">+ Add row</button>
                <br /><button type="submit" class="btn btn-primary">Save schedule</button>
            </form>
        </div>

        <div class="card-section mb-4">
            <h2 class="h5 mb-3">Time off</h2>
            <form asp-action="AddTimeOff" method="post" class="row g-2 align-items-end mb-3">
                @Html.AntiForgeryToken()
                <div class="col-md-4"><label class="form-label small">Start (UTC)</label><input name="startUtc" type="datetime-local" class="form-control form-control-sm" required /></div>
                <div class="col-md-4"><label class="form-label small">End (UTC)</label><input name="endUtc" type="datetime-local" class="form-control form-control-sm" required /></div>
                <div class="col-md-3"><label class="form-label small">Reason</label><input name="reason" class="form-control form-control-sm" placeholder="Vacation, sick, ..." /></div>
                <div class="col-md-1"><button class="btn btn-sm btn-primary w-100">Add</button></div>
            </form>
            <ul class="list-group list-group-flush">
                @if (!Model.Upcoming.Any()) { <li class="list-group-item text-muted">No upcoming time off.</li> }
                @foreach (var t in Model.Upcoming)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@t.StartUtc.ToString("MMM d HH:mm") - @t.EndUtc.ToString("MMM d HH:mm")</strong>
                            <span class="text-muted small ms-2">@t.Reason</span>
                        </div>
                        <form asp-action="DeleteTimeOff" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@t.Id" />
                            <button class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card-section">
            <h2 class="h5 mb-3">Profile & services</h2>
            <form asp-action="SaveProfile" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Specialty</label>
                    <input name="specialty" class="form-control" value="@Model.Specialty" maxlength="150" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Bio</label>
                    <textarea name="bio" class="form-control" rows="4" maxlength="2000">@Model.Bio</textarea>
                </div>
                <hr />
                <label class="form-label">Services I offer</label>
                <div class="border rounded p-3" style="max-height:300px;overflow-y:auto">
                    @foreach (var s in Model.AllServices)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="serviceIds" value="@s.Id" id="svc-@s.Id"
                                   checked="@Model.SelectedServiceIds.Contains(s.Id)" />
                            <label class="form-check-label" for="svc-@s.Id">
                                <strong>@s.Name</strong> · @s.DurationMinutes min · @s.Price.ToString("C")
                            </label>
                        </div>
                    }
                </div>
                <button class="btn btn-primary mt-3 w-100">Save profile</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('add-hours-row').addEventListener('click', () => {
            const tbody = document.getElementById('hours-body');
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><select name="dayOfWeek" class="form-select form-select-sm">
                    <option value="0">Sunday</option><option value="1">Monday</option><option value="2">Tuesday</option>
                    <option value="3">Wednesday</option><option value="4">Thursday</option><option value="5">Friday</option><option value="6">Saturday</option>
                </select></td>
                <td><input name="startMinutes" type="number" min="0" max="1440" value="540" class="form-control form-control-sm" /></td>
                <td><input name="endMinutes" type="number" min="0" max="1440" value="1020" class="form-control form-control-sm" /></td>
                <td><button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button></td>`;
            tbody.appendChild(tr);
        });
        document.getElementById('hours-body').addEventListener('click', e => {
            if (e.target.classList.contains('remove-row')) e.target.closest('tr').remove();
        });
    </script>
}
