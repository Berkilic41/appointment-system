@model RegisterViewModel
@{ ViewData["Title"] = "Register"; }

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card-section">
            <h2 class="h4 mb-4">Create your account</h2>
            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div class="alert alert-danger" asp-validation-summary="ModelOnly"></div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label">Full name</label>
                    <input asp-for="FullName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label">Phone (optional)</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm</label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                    </div>
                </div>
                <button class="btn btn-primary w-100">Create account</button>
            </form>
            <p class="mt-3 mb-0 text-muted text-center small">Already have an account? <a asp-action="Login">Sign in</a></p>
        </div>
    </div>
</div>
